# Resend (mejlutskick) — hämta från resend.com
RESEND_API_KEY=

# Hemlig nyckel för cron-jobbet — hitta på ett slumpmässigt ord/sträng
CRON_SECRET=

# Din publicerade Vercel-URL (utan snedstreck på slutet)
NEXT_PUBLIC_SITE_URL=https://din-blogg.vercel.app

# Upstash Redis — hämta från console.upstash.com → din databas → REST API
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
